Options -MultiViews
DirectoryIndex index.html

RewriteEngine On
RewriteBase /

# Don't rewrite the root index file.
RewriteRule ^index\.html$ - [L]

# Serve existing files/directories directly (including /external/*).
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA fallback for client-side routes like /about, /contact, /services/*.
RewriteRule . /index.html [L]
